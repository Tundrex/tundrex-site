  <!-- ===================== PROTOCOL TILES ===================== -->
  <style>
    /* 5-tile grid: 3 top row, 2 centered bottom row */
    .proto-tiles-grid {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 28px;
    }
    .proto-tile { grid-column: span 2; }
    .proto-tile:nth-child(4) { grid-column: 2 / span 2; }
    .proto-tile:nth-child(5) { grid-column: 4 / span 2; }
    .proto-tile {
      position: relative;
      border-radius: 20px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      min-height: 420px;
      cursor: pointer;
      text-decoration: none;
      color: inherit;
      transition: transform 0.3s cubic-bezier(0.16,1,0.3,1), box-shadow 0.3s;
      box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    }
    .proto-tile:hover { transform: translateY(-8px); box-shadow: 0 28px 80px rgba(0,0,0,0.55); }
    .proto-tile-bg { position: absolute; inset: 0; z-index: 0; }
    .proto-tile-bg--immunity   { background: linear-gradient(150deg, #071705 0%, #122E08 45%, #1B4B0D 75%, #0D2806 100%); }
    .proto-tile-bg--microbiome { background: linear-gradient(150deg, #051208 0%, #0D2E18 45%, #163D22 75%, #0A2410 100%); }
    .proto-tile-bg--supplement { background: linear-gradient(150deg, #0A0812 0%, #1A1030 45%, #2A1848 75%, #150D28 100%); }
    .proto-tile-bg--wellbeing  { background: linear-gradient(150deg, #050E12 0%, #0C2532 45%, #13364A 75%, #082030 100%); }
    .proto-tile-bg--git        { background: linear-gradient(150deg, #120805 0%, #2E1508 45%, #4B2A0D 75%, #281406 100%); }
    .proto-tile-bg--immunity::after   { content:''; position:absolute; top:38%; left:50%; transform:translate(-50%,-50%); width:280px; height:280px; background:radial-gradient(circle, rgba(90,158,56,0.28) 0%, transparent 70%); border-radius:50%; pointer-events:none; }
    .proto-tile-bg--microbiome::after { content:''; position:absolute; top:38%; left:50%; transform:translate(-50%,-50%); width:280px; height:280px; background:radial-gradient(circle, rgba(57,140,100,0.24) 0%, transparent 70%); border-radius:50%; pointer-events:none; }
    .proto-tile-bg--supplement::after { content:''; position:absolute; top:38%; left:50%; transform:translate(-50%,-50%); width:280px; height:280px; background:radial-gradient(circle, rgba(120,80,200,0.22) 0%, transparent 70%); border-radius:50%; pointer-events:none; }
    .proto-tile-bg--wellbeing::after  { content:''; position:absolute; top:38%; left:50%; transform:translate(-50%,-50%); width:280px; height:280px; background:radial-gradient(circle, rgba(56,130,180,0.22) 0%, transparent 70%); border-radius:50%; pointer-events:none; }
    .proto-tile-bg--git::after        { content:''; position:absolute; top:38%; left:50%; transform:translate(-50%,-50%); width:280px; height:280px; background:radial-gradient(circle, rgba(180,100,30,0.24) 0%, transparent 70%); border-radius:50%; pointer-events:none; }
    .proto-tile-badge { position:absolute; top:16px; right:16px; z-index:3; background:linear-gradient(135deg,#C9A84C,#E8C96A); color:#1a0f00; font-size:0.7rem; font-weight:800; border-radius:100px; padding:5px 13px; letter-spacing:0.05em; box-shadow:0 2px 12px rgba(201,168,76,0.45); white-space:nowrap; }
    .proto-tile-inner { position:relative; z-index:2; display:flex; flex-direction:column; height:100%; }
    .proto-tile-top { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:44px 28px 24px; text-align:center; }
    .proto-tile-icon-wrap { width:68px; height:68px; border-radius:18px; background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.13); display:flex; align-items:center; justify-content:center; margin-bottom:20px; }
    .proto-tile-name { font-family:var(--font-serif); font-size:1.6rem; font-weight:800; color:#fff; line-height:1.15; margin-bottom:8px; }
    .proto-tile-duration { font-size:0.72rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; color:rgba(255,255,255,0.48); }
    .proto-tile-bottom { padding:22px 26px 26px; background:rgba(0,0,0,0.32); backdrop-filter:blur(4px); border-top:1px solid rgba(255,255,255,0.07); }
    .proto-tile-desc { font-size:0.84rem; color:rgba(255,255,255,0.7); line-height:1.55; margin-bottom:14px; }
    .proto-tile-pricing { display:flex; align-items:center; gap:10px; margin-bottom:16px; }
    .proto-tile-price { font-size:1.45rem; font-weight:700; color:#fff; }
    .proto-tile-old { font-size:0.88rem; color:rgba(255,255,255,0.42); text-decoration:line-through; }
    .proto-tile-cta { display:block; text-align:center; padding:11px 20px; background:rgba(90,158,56,0.18); border:1.5px solid rgba(90,158,56,0.45); color:#7DC455; font-size:0.84rem; font-weight:700; border-radius:10px; transition:background 0.2s, color 0.2s; letter-spacing:0.02em; }
    .proto-tile:hover .proto-tile-cta { background:rgba(90,158,56,0.32); color:#A8D98A; }
    @media (max-width:900px) { .proto-tiles-grid { grid-template-columns:1fr; } .proto-tile,.proto-tile:nth-child(4),.proto-tile:nth-child(5) { grid-column: span 1; min-height:360px; } }
