  <script src="js/main.js"></script>
  <script>
    // Hero entrance animation
    window.addEventListener('load', () => {
      const heroEls = document.querySelectorAll('#heroContent > *');
      heroEls.forEach((el, i) => {
        setTimeout(() => {
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        }, 300 + i * 160);
      });
    });
  </script>
  <script>
    // ── Articles Carousel ──────────────────────────────────────────
    (function () {
      const track  = document.getElementById('articlesTrack');
      const prev   = document.getElementById('carouselPrev');
      const next   = document.getElementById('carouselNext');
      const dotsEl = document.getElementById('carouselDots');
      if (!track) return;

      const cards      = Array.from(track.querySelectorAll('.accard'));
      const perPage    = () => window.innerWidth <= 768 ? 1 : 3;
      const totalPages = () => Math.ceil(cards.length / perPage());
      let   currentPage = 0;

      // Build dots
      function buildDots () {
        dotsEl.innerHTML = '';
        for (let i = 0; i < totalPages(); i++) {
          const d = document.createElement('span');
          d.className = 'carousel-dot' + (i === currentPage ? ' active' : '');
          d.addEventListener('click', () => goTo(i));
          dotsEl.appendChild(d);
        }
      }

      function updateDots () {
        Array.from(dotsEl.children).forEach((d, i) => {
          d.classList.toggle('active', i === currentPage);
        });
      }

      function updateArrows () {
        prev.disabled = currentPage === 0;
        next.disabled = currentPage >= totalPages() - 1;
      }

      function goTo (page) {
        currentPage = Math.max(0, Math.min(page, totalPages() - 1));
        const cardWidth   = cards[0].offsetWidth + 12; // gap=12
        track.scrollTo({ left: currentPage * perPage() * cardWidth, behavior: 'smooth' });
        updateDots();
        updateArrows();
      }

      prev.addEventListener('click', () => goTo(currentPage - 1));
      next.addEventListener('click', () => goTo(currentPage + 1));

      // Sync dots on scroll
      track.addEventListener('scroll', () => {
        const cardWidth = cards[0].offsetWidth + 12;
        const raw = track.scrollLeft / (perPage() * cardWidth);
        currentPage = Math.round(raw);
        updateDots();
        updateArrows();
      }, { passive: true });

      // Rebuild on resize
      let resizeTimer;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => { buildDots(); goTo(0); }, 150);
      });

      buildDots();
      updateArrows();
    })();
  </script>

  <script>
    // ── Reviews Carousel: homeRev ──────────────────────────────
    (function () {
      const track  = document.getElementById('homeRevTrack');
      const prev   = document.getElementById('homeRevPrev');
      const next   = document.getElementById('homeRevNext');
      const dotsEl = document.getElementById('homeRevDots');
      if (!track) return;
      const cards      = Array.from(track.querySelectorAll('.review-card'));
      const perPage    = () => window.innerWidth <= 600 ? 1 : (window.innerWidth <= 900 ? 2 : 3);
      const totalPages = () => Math.ceil(cards.length / perPage());
      let   currentPage = 0;
      function buildDots() {
        dotsEl.innerHTML = '';
        for (let i = 0; i < totalPages(); i++) {
          const d = document.createElement('span');
          d.className = 'carousel-dot' + (i === currentPage ? ' active' : '');
          d.addEventListener('click', () => goTo(i));
          dotsEl.appendChild(d);
        }
      }
      function updateDots() { Array.from(dotsEl.children).forEach((d, i) => d.classList.toggle('active', i === currentPage)); }
      function updateArrows() { prev.disabled = currentPage === 0; next.disabled = currentPage >= totalPages() - 1; }
      function goTo(page) {
        currentPage = Math.max(0, Math.min(page, totalPages() - 1));
        const gap = 20;
        const cardW = cards[0].offsetWidth + gap;
        track.scrollTo({ left: currentPage * perPage() * cardW, behavior: 'smooth' });
        updateDots(); updateArrows();
      }
      prev.addEventListener('click', () => goTo(currentPage - 1));
      next.addEventListener('click', () => goTo(currentPage + 1));
      track.addEventListener('scroll', () => {
        const cardW = cards[0].offsetWidth + 20;
        const pp = perPage();
        currentPage = Math.round(track.scrollLeft / (pp * cardW));
        updateDots(); updateArrows();
      }, { passive: true });
      let rt;
      window.addEventListener('resize', () => { clearTimeout(rt); rt = setTimeout(() => { buildDots(); goTo(0); }, 150); });
      buildDots(); updateArrows();
    })();
  </script>
</body>
</html>
